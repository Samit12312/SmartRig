<Window x:Class="SmartRigWPF.Frames.OrderDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartRigWPF.Frames"
        mc:Ignorable="d"
        Title="Order Details" Height="450" Width="800"
        Background="White">
    <Canvas>

        <TextBlock Canvas.Left="20" Canvas.Top="20"
                   Text="Order Details"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"/>

        <TextBlock x:Name="OrderIdText"
                   Canvas.Left="20" Canvas.Top="60"
                   FontSize="13"
                   Foreground="#7f8c8d"/>

        <TextBlock x:Name="UserIdText"
                   Canvas.Left="20" Canvas.Top="80"
                   FontSize="13"
                   Foreground="#7f8c8d"/>

        <TextBlock x:Name="DateText"
                   Canvas.Left="20" Canvas.Top="100"
                   FontSize="13"
                   Foreground="#7f8c8d"/>

        <TextBlock Canvas.Left="20" Canvas.Top="130"
                   Text="Payment Status"
                   FontSize="13"
                   Foreground="#2c3e50"/>

        <CheckBox x:Name="IsPayedBox"
                  Canvas.Left="20" Canvas.Top="155"
                  Content="Paid"
                  FontSize="13"
                  Foreground="#2c3e50"/>

        <TextBlock Canvas.Left="20" Canvas.Top="190"
                   Text="Computers in this order"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"/>

        <ListView x:Name="ComputersListView"
                  Canvas.Left="20" Canvas.Top="215"
                  Width="740" Height="150"
                  BorderBrush="#dee2e6"
                  BorderThickness="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ComputerName}" FontWeight="SemiBold" Width="200"/>
                            <TextBlock Text="Price: " Foreground="#7f8c8d" Margin="20,0,0,0"/>
                            <TextBlock Text="{Binding ComputerPrice}" Foreground="#27ae60" FontWeight="Bold" Width="80"/>
                            <TextBlock Text="Qty: " Foreground="#7f8c8d"/>
                            <TextBlock Text="{Binding ComputerQuantity}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button x:Name="SaveBtn"
                Canvas.Left="20" Canvas.Top="385"
                Content="Save Changes"
                Width="150" Height="35"
                Background="#27ae60"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="SaveBtn_Click"/>

        <Button x:Name="CancelBtn"
                Canvas.Left="180" Canvas.Top="385"
                Content="Cancel"
                Width="100" Height="35"
                Background="#e74c3c"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="CancelBtn_Click"/>

    </Canvas>
</Window>