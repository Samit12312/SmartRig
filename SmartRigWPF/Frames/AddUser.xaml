<Window x:Class="SmartRigWPF.Frames.AddUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" 
        Background="White"
        Width="530" Height="450"
        Title="Add User">
    <Canvas>

        <!-- Title -->
        <TextBlock x:Name="TitleText"
                   Canvas.Left="20" Canvas.Top="20"
                   Text="Add User"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"/>

        <!-- User Name -->
        <TextBlock Canvas.Left="20" Canvas.Top="70"
                   Text="User Name"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="UserNameBox"
                 Canvas.Left="20" Canvas.Top="90"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"/>

        <!-- Email -->
        <TextBlock Canvas.Left="290" Canvas.Top="70"
                   Text="Email"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="UserEmailBox"
                 Canvas.Left="290" Canvas.Top="90"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"/>

        <!-- Password -->
        <TextBlock Canvas.Left="20" Canvas.Top="140"
                   Text="Password"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <PasswordBox x:Name="UserPasswordBox"
                     Canvas.Left="20" Canvas.Top="160"
                     Width="200" Height="30"
                     Padding="5"
                     BorderBrush="#dee2e6"/>
        <TextBlock Canvas.Left="20" Canvas.Top="195"
           Text="Leave blank to keep current password"
           FontSize="11"
           Foreground="#7f8c8d"/>

        <!-- Phone -->
        <TextBlock Canvas.Left="290" Canvas.Top="140"
                   Text="Phone Number"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="UserPhoneBox"
                 Canvas.Left="290" Canvas.Top="160"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"/>

        <!-- Address -->
        <TextBlock Canvas.Left="20" Canvas.Top="210"
                   Text="Address"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="UserAddressBox"
                 Canvas.Left="20" Canvas.Top="230"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"/>

        <!-- City -->
        <TextBlock Canvas.Left="290" Canvas.Top="210"
                   Text="City"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="CityBox"
                  Canvas.Left="290" Canvas.Top="230"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="CityName"
                  SelectedValuePath="CityId"
                  BorderBrush="#dee2e6"/>

        <!-- Manager -->
        <TextBlock Canvas.Left="20" Canvas.Top="280"
                   Text="Manager"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <CheckBox x:Name="ManagerBox"
                  Canvas.Left="20" Canvas.Top="305"
                  Content="Is Manager"
                  FontSize="13"
                  Foreground="#2c3e50"/>

        <!-- Add Button -->
        <Button x:Name="AddBtn"
                Canvas.Left="20" Canvas.Top="360"
                Content="Add User"
                Width="150" Height="35"
                Background="#27ae60"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="AddBtn_Click"/>

        <!-- Cancel Button -->
        <Button x:Name="CancelBtn"
                Canvas.Left="180" Canvas.Top="360"
                Content="Cancel"
                Width="100" Height="35"
                Background="#e74c3c"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="CancelBtn_Click"/>

        <!-- Message -->
        <TextBlock x:Name="MessageText"
                   Canvas.Left="20" Canvas.Top="405"
                   FontSize="13"
                   Foreground="#e74c3c"/>

    </Canvas>
</Window>