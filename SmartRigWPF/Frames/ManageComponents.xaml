<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="SmartRigWPF.Frames.ManageComponents"
    Background="White"
    Width="750" Height="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,200">
        <StackPanel Margin="20" x:Name="MainStack" >

            <!-- CPU Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage CPUs" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add CPU" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddCpu_Click"/>
                    <Button Content="Edit CPU" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditCpu_Click"/>
                    <Button Content="Delete CPU" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeleteCpu_Click"/>
                </StackPanel>
                <ListView x:Name="cpuListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding CpuName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CpuId, StringFormat=CPU ID: {0}}" FontSize="12" Foreground="#7f8c8d"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Price: " Width="120"/>
                                        <TextBlock Text="{Binding CpuPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding CpuCompanyId}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- GPU Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage GPUs" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add GPU" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddGpu_Click"/>
                    <Button Content="Edit GPU" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditGpu_Click"/>
                    <Button Content="Delete GPU" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeleteGpu_Click"/>
                </StackPanel>
                <ListView x:Name="gpuListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding GpuName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding GpuId, StringFormat=GPU ID: {0}}" FontSize="12" Foreground="#7f8c8d"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Size: " Width="120"/>
                                        <TextBlock Text="{Binding GpuSize}"/>
                                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding GpuSpeed}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Price: " Width="120"/>
                                        <TextBlock Text="{Binding GpuPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding GpuCompanyId}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- RAM Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage RAMs" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add RAM" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddRam_Click"/>
                    <Button Content="Edit RAM" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditRam_Click"/>
                    <Button Content="Delete RAM" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeleteRam_Click"/>
                </StackPanel>
                <ListView x:Name="ramListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding RamName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding RamId, StringFormat=RAM ID: {0}}" FontSize="12" Foreground="#7f8c8d"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Size: " Width="120"/>
                                        <TextBlock Text="{Binding RamSize}"/>
                                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding RamSpeed}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Type ID: " Width="120"/>
                                        <TextBlock Text="{Binding RamTypeId}"/>
                                        <TextBlock Text="Price: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding RamPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding RamCompanyId}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            <!-- Storage Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage Storages" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add Storage" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddStorage_Click"/>
                    <Button Content="Edit Storage" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditStorage_Click"/>
                    <Button Content="Delete Storage" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeleteStorage_Click"/>
                </StackPanel>
                <ListView x:Name="storageListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding StorageName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding StorageId, StringFormat=Storage ID: {0}}" FontSize="12" Foreground="#7f8c8d"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Size: " Width="120"/>
                                        <TextBlock Text="{Binding StorageSize}"/>
                                        <TextBlock Text="Type: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding StorageType}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Price: " Width="120"/>
                                        <TextBlock Text="{Binding StoragePrice}" FontWeight="Bold" Foreground="#27ae60"/>
                                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding StorageCompanyId}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Motherboard Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage Motherboards" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add Motherboard" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddMotherBoard_Click"/>
                    <Button Content="Edit Motherboard" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditMotherBoard_Click"/>
                    <Button Content="Delete Motherboard" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeleteMotherBoard_Click"/>
                </StackPanel>
                <ListView x:Name="motherBoardListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding MotherBoardName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding MotherBoardId, StringFormat=Motherboard ID: {0}}" FontSize="12" Foreground="#7f8c8d"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Form Factor: " Width="120"/>
                                        <TextBlock Text="{Binding FormFactor}"/>
                                        <TextBlock Text="Socket: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding Socket}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Price: " Width="120"/>
                                        <TextBlock Text="{Binding MotherBoardPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding MotherBoardCompanyId}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- CPU Fan Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage CPU Fans" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add CPU Fan" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddCpuFan_Click"/>
                    <Button Content="Edit CPU Fan" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditCpuFan_Click"/>
                    <Button Content="Delete CPU Fan" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeleteCpuFan_Click"/>
                </StackPanel>
                <ListView x:Name="cpuFanListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding CpuFanName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CpuFanId, StringFormat=CPU Fan ID: {0}}" FontSize="12" Foreground="#7f8c8d"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="RPM: " Width="120"/>
                                        <TextBlock Text="{Binding Rpm}"/>
                                        <TextBlock Text="Price: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding CpuFanPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding CpuFanCompanyId, StringFormat=Company ID: {0}}" FontSize="12" Foreground="#7f8c8d" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Power Supply Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage Power Supplies" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add PSU" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddPowerSupply_Click"/>
                    <Button Content="Edit PSU" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditPowerSupply_Click"/>
                    <Button Content="Delete PSU" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeletePowerSupply_Click"/>
                </StackPanel>
                <ListView x:Name="powerSupplyListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding PsuName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="PSU ID: {Binding PsuId}" FontSize="12" Foreground="#7f8c8d"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <TextBlock Text="Wattage: " Width="120"/>
                                        <TextBlock Text="{Binding Wattage}"/>
                                        <TextBlock Text="Price: " Width="120" Margin="20,0,0,0"/>
                                        <TextBlock Text="{Binding PsuPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding PsuCompanyId, StringFormat=Company ID: {0}}" FontSize="12" Foreground="#7f8c8d" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- OS Grid -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Manage Operating Systems" FontSize="22" FontWeight="SemiBold" Grid.Row="0" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <Button Content="Add OS" Width="120" Height="30" Background="#27ae60" Foreground="White" Margin="0,0,10,0" Click="AddOs_Click"/>
                    <Button Content="Edit OS" Width="120" Height="30" Background="#3498db" Foreground="White" Margin="0,0,10,0" Click="EditOs_Click"/>
                    <Button Content="Delete OS" Width="120" Height="30" Background="#e74c3c" Foreground="White" Click="DeleteOs_Click"/>
                </StackPanel>
                <ListView x:Name="osListView" Grid.Row="2" BorderBrush="#dee2e6" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding OsName}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OsId, StringFormat=OS ID: {0}}" FontSize="12" Foreground="#7f8c8d"/>
                                    <TextBlock Text="{Binding OsPrice, StringFormat=Price: {0}}" FontSize="12" Foreground="#27ae60" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding OsCompanyId, StringFormat=Company ID: {0}}" FontSize="12" Foreground="#7f8c8d" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>