<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:Models;assembly=Models"
    x:Class="SmartRigWPF.Frames.ManageComponents"
    Background="White"
    Width="730" Height="540">

    <UserControl.Resources>
        <!-- CPU Template -->
        <DataTemplate DataType="{x:Type models:Cpu}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding CpuName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="CPU ID: "/>
                        <Run Text="{Binding CpuId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding CpuPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding CpuCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- GPU Template -->
        <DataTemplate DataType="{x:Type models:Gpu}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding GpuName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="GPU ID: "/>
                        <Run Text="{Binding GpuId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Size: " Width="80"/>
                        <TextBlock Text="{Binding GpuSize}"/>
                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding GpuSpeed}"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding GpuPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding GpuCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- RAM Template -->
        <DataTemplate DataType="{x:Type models:Ram}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding RamName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="RAM ID: "/>
                        <Run Text="{Binding RamId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Size: " Width="80"/>
                        <TextBlock Text="{Binding RamSize}"/>
                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding RamSpeed}"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding RamPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding RamCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Storage Template -->
        <DataTemplate DataType="{x:Type models:Storage}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding StorageName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="Storage ID: "/>
                        <Run Text="{Binding StorageId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Size: " Width="80"/>
                        <TextBlock Text="{Binding StorageSize}"/>
                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding StorageSpeed}"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Type: " Width="80"/>
                        <TextBlock Text="{Binding StorageType}"/>
                        <TextBlock Text="Price: $" Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding StoragePrice}" FontWeight="Bold" Foreground="#27ae60"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Company ID: " Width="80"/>
                        <TextBlock Text="{Binding StorageCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Motherboard Template -->
        <DataTemplate DataType="{x:Type models:MotherBoard}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding MotherBoardName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="Motherboard ID: "/>
                        <Run Text="{Binding MotherBoardId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding MotherBoardPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding MotherBoardCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- CPU Fan Template -->
        <DataTemplate DataType="{x:Type models:CpuFan}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding CpuFanName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="CPU Fan ID: "/>
                        <Run Text="{Binding CpuFanId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding CpuFanPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company ID: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding CpuFanCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Power Supply Template -->
        <DataTemplate DataType="{x:Type models:PowerSupply}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding PowerSupplyName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="Power Supply ID: "/>
                        <Run Text="{Binding PowerSupplyId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Wattage: " Width="80"/>
                        <TextBlock Text="{Binding PowerSupplyWattage}"/>
                        <TextBlock Text="Price: $" Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding PowerSupplyPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Company ID: " Width="80"/>
                        <TextBlock Text="{Binding PowerSupplyCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Operating System Template -->
        <DataTemplate DataType="{x:Type models:OperatingSystem}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding OperatingSystemName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                        <Run Text="OS ID: "/>
                        <Run Text="{Binding OperatingSystemId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding OperatingSystemPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding OperatingSystemCompanyId}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- Title -->
        <TextBlock Text="Manage Components"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"
                   Margin="20,20,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <!-- Filter and Action Buttons -->
        <StackPanel Orientation="Horizontal"
            Margin="20,65,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">

            <TextBlock Text="Filter:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       FontWeight="SemiBold"/>

            <ComboBox x:Name="ComponentTypeComboBox"
                      Width="140"
                      Height="35"
                      SelectionChanged="ComponentTypeComboBox_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="CPU"/>
                <ComboBoxItem Content="GPU"/>
                <ComboBoxItem Content="RAM"/>
                <ComboBoxItem Content="Storage"/>
                <ComboBoxItem Content="Motherboard"/>
                <ComboBoxItem Content="CPU Fan"/>
                <ComboBoxItem Content="Power Supply"/>
                <ComboBoxItem Content="Operating System"/>
            </ComboBox>

            <Button Content="Add" Width="80" Height="35"
            Background="#27ae60" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="20,0,0,0"/>
            <Button Content="Edit" Width="80" Height="35"
            Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0"/>
            <Button Content="Delete" Width="80" Height="35"
            Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0"/>
        </StackPanel>

        <!-- ListView -->
        <ListView x:Name="listView"
          Margin="20,120,20,30"
          BorderBrush="#dee2e6"
          BorderThickness="1"
          Height="200"
          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Grid>
</UserControl>