<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:Models.ViewModels;assembly=Models"  
    x:Class="SmartRigWPF.Frames.ManageComponents"
    Background="White"
    Width="730" Height="540">

    <UserControl.Resources>
        <!-- CPU Template -->
        <DataTemplate DataType="{x:Type viewModels:CpuManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding cpu.CpuName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="CPU ID: "/>
                <Run Text="{Binding cpu.CpuId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding cpu.CpuPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- GPU Template -->
        <DataTemplate DataType="{x:Type viewModels:GpuManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding gpu.GpuName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="GPU ID: "/>
                <Run Text="{Binding gpu.GpuId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Size: " Width="80"/>
                        <TextBlock Text="{Binding gpu.GpuSize}"/>
                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding gpu.GpuSpeed}"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding gpu.GpuPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- RAM Template -->
        <DataTemplate DataType="{x:Type viewModels:RamManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding ram.RamName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="RAM ID: "/>
                <Run Text="{Binding ram.RamId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Size: " Width="80"/>
                        <TextBlock Text="{Binding ram.RamSize}"/>
                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding ram.RamSpeed}"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Type: " Width="80"/>
                        <TextBlock Text="{Binding type.TypeName}"/>
                        <TextBlock Text="Price: $" Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding ram.RamPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Company: " Width="80"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Storage Template -->
        <DataTemplate DataType="{x:Type viewModels:StorageManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding storage.StorageName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="Storage ID: "/>
                <Run Text="{Binding storage.StorageId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Size: " Width="80"/>
                        <TextBlock Text="{Binding storage.StorageSize}"/>
                        <TextBlock Text="Speed: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding storage.StorageSpeed}"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Type: " Width="80"/>
                        <TextBlock Text="{Binding type.TypeName}"/>
                        <TextBlock Text="Price: $" Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding storage.StoragePrice}" FontWeight="Bold" Foreground="#27ae60"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Company: " Width="80"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Motherboard Template -->
        <DataTemplate DataType="{x:Type viewModels:MotherBoardManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding motherBoard.MotherBoardName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="Motherboard ID: "/>
                <Run Text="{Binding motherBoard.MotherBoardId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding motherBoard.MotherBoardPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- CPU Fan Template -->
        <DataTemplate DataType="{x:Type viewModels:CpuFanManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding cpuFan.CpuFanName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="CPU Fan ID: "/>
                <Run Text="{Binding cpuFan.CpuFanId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding cpuFan.CpuFanPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <!-- Power Supply Template -->
        <DataTemplate DataType="{x:Type viewModels:PowerSupplyManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding powerSupply.PowerSupplyName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="Power Supply ID: "/>
                <Run Text="{Binding powerSupply.PowerSupplyId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Wattage: " Width="80"/>
                        <TextBlock Text="{Binding powerSupply.PowerSupplyWatt}"/>
                        <TextBlock Text="Price: $" Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding powerSupply.PowerSupplyPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Company: " Width="80"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Operating System Template -->
        <DataTemplate DataType="{x:Type viewModels:OperatingSystemManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding operatingSystem.OperatingSystemName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="OS ID: "/>
                <Run Text="{Binding operatingSystem.OperatingSystemId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding operatingSystem.OperatingSystemPrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <!-- Case Template -->
        <DataTemplate DataType="{x:Type viewModels:CaseManageViewModel}">
            <Border Padding="12" BorderBrush="#ecf0f1" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding computerCase.CaseName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                <Run Text="Case ID: "/>
                <Run Text="{Binding computerCase.CaseId}"/>
                    </TextBlock>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Price: $" Width="80"/>
                        <TextBlock Text="{Binding computerCase.CasePrice}" FontWeight="Bold" Foreground="#27ae60"/>
                        <TextBlock Text="Company: " Width="120" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding company.CompanyName}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- Title -->
        <TextBlock Text="Manage Components"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"
                   Margin="20,20,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <!-- Filter and Action Buttons -->
        <StackPanel Orientation="Horizontal"
            Margin="20,65,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">

            <TextBlock Text="Filter:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       FontWeight="SemiBold"/>

            <ComboBox x:Name="ComponentTypeComboBox"
                      Width="140"
                      Height="35"
                      SelectionChanged="ComponentTypeComboBox_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="CPU"/>
                <ComboBoxItem Content="GPU"/>
                <ComboBoxItem Content="RAM"/>
                <ComboBoxItem Content="Storage"/>
                <ComboBoxItem Content="Motherboard"/>
                <ComboBoxItem Content="Case"/>
                <ComboBoxItem Content="CPU Fan"/>
                <ComboBoxItem Content="Power Supply"/>
                <ComboBoxItem Content="Operating System"/>
            </ComboBox>
            <Button Content="Add" Width="80" Height="35"
        Background="#27ae60" Foreground="White" BorderThickness="0" Cursor="Hand"
        Margin="20,0,0,0"
        Click="AddBtn_Click"/>

            <Button Content="Edit" Width="80" Height="35"
        Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand"
        Margin="10,0,0,0"
        Click="EditBtn_Click"/>

            <Button Content="Delete" Width="80" Height="35"
        Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand"
        Margin="10,0,0,0"/>
        </StackPanel>

        <!-- ListView -->
        <ListView x:Name="listView"
          Margin="20,120,20,30"
          BorderBrush="#dee2e6"
          BorderThickness="1"
          Height="200"
          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Grid>
</UserControl>