<UserControl x:Class="SmartRigWPF.Frames.ManageReports"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Manage Reports"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"
                   Margin="0,0,0,15"/>

        <!-- Date Range Selector -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="From:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <DatePicker Name="StartDatePicker"
                            Width="120"
                            Height="28"
                            Margin="0,0,15,0"/>

                <TextBlock Text="To:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <DatePicker Name="EndDatePicker"
                            Width="120"
                            Height="28"
                            Margin="0,0,15,0"/>

                <Button Content="Generate Report"
                        Width="120"
                        Height="28"
                        Background="#3498db"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Button_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Income Display -->
        <Border Grid.Row="2"
                BorderBrush="#ddd"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                Background="#f8f9fa"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Total Income"
                           FontSize="14"
                           Foreground="#666"
                           Margin="0,0,0,5"/>
                <TextBlock Name="TotalIncomeText"
                           Text="$0.00"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#27ae60"/>
                <TextBlock Name="DateRangeText"
                           Text="Select date range and click Generate Report"
                           FontSize="12"
                           Foreground="#999"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Most Selling Computer -->
        <Border Grid.Row="3"
                BorderBrush="#ddd"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15"
                Background="White">
            <StackPanel>
                <TextBlock Text="Most Selling Computer"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#2c3e50"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Computer Image -->
                    <Border Grid.Column="0"
                            BorderBrush="#ddd"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="5"
                            Background="#f8f9fa"
                            Width="100"
                            Height="100"
                            Margin="0,0,15,0">
                        <Image Name="MostSellingComputerImage"
                               Stretch="Uniform"
                               Source="/Images/Mundo.png"/>
                    </Border>

                    <!-- Computer Details -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="ID: "
                                       FontSize="12"
                                       Foreground="#666"/>
                            <TextBlock Name="ComputerIdText"
                                       Text="---"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Name="ComputerNameText"
                                   Text="---"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>

                        <TextBlock Name="ComputerPriceText"
                                   Text="$---"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#27ae60"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>