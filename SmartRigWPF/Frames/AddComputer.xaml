<Window x:Class="SmartRigWPF.Frames.AddComputer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Background="White"
             Width="730" Height="540">
    <Canvas>
        <!-- Title -->
        <TextBlock Canvas.Left="20" Canvas.Top="20"
                   Text="Add Computer"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"/>

        <!-- Computer Name -->
        <TextBlock Canvas.Left="20" Canvas.Top="70"
                   Text="Computer Name"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="ComputerNameBox"
                 Canvas.Left="20" Canvas.Top="90"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"/>

        <!-- Price -->
        <TextBlock Canvas.Left="240" Canvas.Top="70"
                   Text="Price"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="PriceBox"
                 Canvas.Left="240" Canvas.Top="90"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"/>

        <!-- Company -->
        <TextBlock Canvas.Left="20" Canvas.Top="140"
                   Text="Company"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="CompanyBox"
                 Canvas.Left="20" Canvas.Top="160"
                 Width="200" Height="30"
                 Padding="5"
                  DisplayMemberPath="CompanyName"
                  SelectedValuePath="CompanyId"
                 BorderBrush="#dee2e6"/>

        <!-- Type -->
        <TextBlock Canvas.Left="240" Canvas.Top="140"
                   Text="Type"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="TypeBox"
          Canvas.Left="240" Canvas.Top="160"
          Width="200" Height="30"
          Padding="5"
          DisplayMemberPath="TypeName"
          SelectedValuePath="TypeId"
          BorderBrush="#dee2e6"/>

        <!-- Operating System -->
        <TextBlock Canvas.Left="20" Canvas.Top="210"
                   Text="Operating System"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="OSBox"
          Canvas.Left="20" Canvas.Top="230"
          Width="200" Height="30"
          Padding="5"
          DisplayMemberPath="CompanyName"
          SelectedValuePath="CompanyId"
          BorderBrush="#dee2e6"/>

        <!-- CPU -->
        <TextBlock Canvas.Left="240" Canvas.Top="210"
                   Text="CPU"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="CpuBox"
          Canvas.Left="240" Canvas.Top="230"
          Width="200" Height="30"
          Padding="5"
          DisplayMemberPath="CpuName"
          SelectedValuePath="CpuId"
          BorderBrush="#dee2e6"/>

        <!-- GPU -->
        <TextBlock Canvas.Left="20" Canvas.Top="280"
                   Text="GPU"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="GpuBox"
          Canvas.Left="20" Canvas.Top="300"
          Width="200" Height="30"
          Padding="5"
          DisplayMemberPath="GpuName"
          SelectedValuePath="GpuId"
          BorderBrush="#dee2e6"/>

        <!-- RAM -->
        <TextBlock Canvas.Left="240" Canvas.Top="280"
                   Text="RAM"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="RamBox"
          Canvas.Left="240" Canvas.Top="300"
          Width="200" Height="30"
          Padding="5"
          DisplayMemberPath="RamSize"
          SelectedValuePath="RamId"
          BorderBrush="#dee2e6"/>

        <!-- Storage -->
        <TextBlock Canvas.Left="20" Canvas.Top="350"
                   Text="Storage"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="StorageBox"
          Canvas.Left="20" Canvas.Top="370"
          Width="200" Height="30"
          Padding="5"
          DisplayMemberPath="StorageName"
          SelectedValuePath="StorageId"
          BorderBrush="#dee2e6"/>

        <!-- Motherboard -->
        <TextBlock Canvas.Left="240" Canvas.Top="350"
                   Text="Motherboard"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="MotherboardBox"
          Canvas.Left="240" Canvas.Top="370"
          Width="200" Height="30"
          Padding="5"
          DisplayMemberPath="MotherBoardName"
          SelectedValuePath="MotherBoardId"
          BorderBrush="#dee2e6"/>

        <!-- Image Preview -->
        <Border Canvas.Left="460" Canvas.Top="70"
                Width="150" Height="150"
                BorderBrush="#dee2e6"
                BorderThickness="1"
                CornerRadius="4">
            <Image x:Name="image"
                   Width="150" Height="150"
                   Stretch="Uniform"/>
        </Border>

        <!-- Upload Image Button -->
        <Button x:Name="UploadImageBtn"
                Canvas.Left="460" Canvas.Top="230"
                Content="Upload Image"
                Width="150" Height="30"
                Background="#3498db"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="UploadImageBtn_Click"/>

        <!-- Add Button -->
        <Button x:Name="AddBtn"
                Canvas.Left="20" Canvas.Top="450"
                Content="Add Computer"
                Width="150" Height="35"
                Background="#27ae60"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="AddBtn_Click"/>

        <!-- Cancel Button -->
        <Button x:Name="CancelBtn"
                Canvas.Left="180" Canvas.Top="450"
                Content="Cancel"
                Width="100" Height="35"
                Background="#e74c3c"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"/>

        <!-- Message -->
        <TextBlock x:Name="MessageText"
                   Canvas.Left="20" Canvas.Top="495"
                   FontSize="13"
                   Foreground="#e74c3c"/>
    </Canvas>
</Window>