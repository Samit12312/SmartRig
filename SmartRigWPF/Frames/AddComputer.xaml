<Window x:Class="SmartRigWPF.Frames.AddComputer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Background="White"
        Width="730" Height="730">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Canvas>

        <TextBlock Canvas.Left="20" Canvas.Top="20"
                   Text="Add Computer"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"/>

        <TextBlock Canvas.Left="20" Canvas.Top="70"
                   Text="Computer Name"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="ComputerNameBox"
                 Canvas.Left="20" Canvas.Top="90"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"
                 Text="{Binding Computer.ComputerName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="20" Canvas.Top="123"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=ComputerNameBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=ComputerNameBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="240" Canvas.Top="70"
                   Text="Price"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <TextBox x:Name="PriceBox"
                 Canvas.Left="240" Canvas.Top="90"
                 Width="200" Height="30"
                 Padding="5"
                 BorderBrush="#dee2e6"
                 Text="{Binding Computer.Price, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="240" Canvas.Top="123"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=PriceBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=PriceBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="20" Canvas.Top="150"
                   Text="Company"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="CompanyBox"
                  Canvas.Left="20" Canvas.Top="170"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="CompanyName"
                  SelectedValuePath="CompanyId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.CompanyId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="20" Canvas.Top="203"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=CompanyBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=CompanyBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="240" Canvas.Top="150"
                   Text="Type"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="TypeBox"
                  Canvas.Left="240" Canvas.Top="170"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="TypeName"
                  SelectedValuePath="TypeId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.ComputerTypeId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="240" Canvas.Top="203"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TypeBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=TypeBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="20" Canvas.Top="230"
                   Text="Operating System"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="OSBox"
                  Canvas.Left="20" Canvas.Top="250"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="OperatingSystemName"
                  SelectedValuePath="OperatingSystemId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.OperatingSystemId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="20" Canvas.Top="283"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=OSBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=OSBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="240" Canvas.Top="230"
                   Text="CPU"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="CpuBox"
                  Canvas.Left="240" Canvas.Top="250"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="CpuName"
                  SelectedValuePath="CpuId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.CpuId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="240" Canvas.Top="283"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=CpuBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=CpuBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="20" Canvas.Top="310"
                   Text="GPU"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="GpuBox"
                  Canvas.Left="20" Canvas.Top="330"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="GpuName"
                  SelectedValuePath="GpuId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.GpuId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="20" Canvas.Top="363"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=GpuBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=GpuBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="240" Canvas.Top="310"
                   Text="RAM"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="RamBox"
                  Canvas.Left="240" Canvas.Top="330"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="RamSize"
                  SelectedValuePath="RamId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.RamId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="240" Canvas.Top="363"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=RamBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=RamBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="20" Canvas.Top="390"
                   Text="Storage"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="StorageBox"
                  Canvas.Left="20" Canvas.Top="410"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="StorageName"
                  SelectedValuePath="StorageId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.StorageId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="20" Canvas.Top="443"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=StorageBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=StorageBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="240" Canvas.Top="390"
                   Text="Motherboard"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="MotherboardBox"
                  Canvas.Left="240" Canvas.Top="410"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="MotherBoardName"
                  SelectedValuePath="MotherBoardId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.MotherBoardId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="240" Canvas.Top="443"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=MotherboardBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=MotherboardBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="20" Canvas.Top="470"
                   Text="Case"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="CaseBox"
                  Canvas.Left="20" Canvas.Top="490"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="CaseName"
                  SelectedValuePath="CaseId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.CaseId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="20" Canvas.Top="523"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=CaseBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=CaseBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="240" Canvas.Top="470"
                   Text="Power Supply"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="PowerSupplyBox"
                  Canvas.Left="240" Canvas.Top="490"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="PowerSupplyName"
                  SelectedValuePath="PowerSupplyId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.PowerSupplyId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="240" Canvas.Top="523"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=PowerSupplyBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=PowerSupplyBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <TextBlock Canvas.Left="20" Canvas.Top="550"
                   Text="CPU Fan"
                   FontSize="13"
                   Foreground="#2c3e50"/>
        <ComboBox x:Name="CpuFanBox"
                  Canvas.Left="20" Canvas.Top="570"
                  Width="200" Height="30"
                  Padding="5"
                  DisplayMemberPath="CpuFanName"
                  SelectedValuePath="CpuFanId"
                  BorderBrush="#dee2e6"
                  SelectedValue="{Binding Computer.CpuFanId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
        <TextBlock Canvas.Left="20" Canvas.Top="603"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=CpuFanBox}"
                   Visibility="{Binding (Validation.HasError), Converter={StaticResource BoolToVis}, ElementName=CpuFanBox}"
                   Foreground="Red"
                   FontSize="11"/>

        <Border Canvas.Left="460" Canvas.Top="70"
                Width="200" Height="200"
                BorderBrush="#dee2e6"
                BorderThickness="1"
                CornerRadius="4">
            <Image x:Name="image"
                   Width="150" Height="150"
                   Stretch="Uniform"/>
        </Border>

        <Button x:Name="UploadImageBtn"
                Canvas.Left="485" Canvas.Top="315"
                Content="Upload Image"
                Width="150" Height="30"
                Background="#3498db"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="UploadImageBtn_Click"/>

        <Button x:Name="AddBtn"
                Canvas.Left="20" Canvas.Top="650"
                Content="Add Computer"
                Width="150" Height="35"
                Background="#27ae60"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="AddBtn_Click"/>

        <Button x:Name="CancelBtn"
        Canvas.Left="180" Canvas.Top="650"
        Content="Cancel"
        Width="100" Height="35"
        Background="#e74c3c"
        Foreground="White"
        BorderThickness="0"
        Cursor="Hand"
        Click="CancelBtn_Click"/>

        <TextBlock x:Name="MessageText"
                   Canvas.Left="460" Canvas.Top="360"
                   FontSize="13"
                   Foreground="#e74c3c"/>
    </Canvas>
</Window>