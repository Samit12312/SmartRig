<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SmartRigWPF"
    x:Class="SmartRigWPF.Frames.ManageComputers"
    Background="White"
    Width="730" Height="540">
    <UserControl.Resources>
        <local:ImageUrlToBitmapConverter x:Key="ImageConverter"/>
    </UserControl.Resources>
    <Grid>

        <TextBlock Text="Manage Computers"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"
                   Margin="20,20,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <StackPanel Orientation="Horizontal"
            Margin="20,65,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <Button Content="Add Computer" Width="120" Height="35"
            Background="#27ae60" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Button_Click"/>
            <Button Content="Edit Computer" Width="120" Height="35"
            Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0" Click="EditBtn_Click" />
            <Button Content="Delete Computer" Width="120" Height="35"
            Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0" Click="Button_Click_1"/>
        </StackPanel>


        <ListView x:Name="listView"
          Margin="20,120,20,30"
          BorderBrush="#dee2e6"
          BorderThickness="1"
                  Height="200"
          ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                    BorderBrush="#ecf0f1"
                    BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock Text="{Binding ComputerName}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                            <Run Text="Computer ID: "/>
                            <Run Text="{Binding ComputerId}"/>
                                </TextBlock>

                                <WrapPanel Margin="0,6,0,0">
                                    <TextBlock Text="CPU: " Width="120"/>
                                    <TextBlock Text="{Binding CpuId}"/>
                                    <TextBlock Text="GPU: " Width="120" Margin="20,0,0,0"/>
                                    <TextBlock Text="{Binding GpuId}"/>
                                </WrapPanel>

                                <WrapPanel>
                                    <TextBlock Text="RAM: " Width="120"/>
                                    <TextBlock Text="{Binding RamId}"/>
                                    <TextBlock Text="Storage: " Width="120" Margin="20,0,0,0"/>
                                    <TextBlock Text="{Binding StorageId}"/>
                                </WrapPanel>

                                <WrapPanel>
                                    <TextBlock Text="Motherboard: " Width="120"/>
                                    <TextBlock Text="{Binding MotherBoardId}"/>
                                    <TextBlock Text="Power Supply: " Width="120" Margin="20,0,0,0"/>
                                    <TextBlock Text="{Binding PowerSupplyId}"/>
                                </WrapPanel>

                                <WrapPanel>
                                    <TextBlock Text="Case: " Width="120"/>
                                    <TextBlock Text="{Binding CaseId}"/>
                                    <TextBlock Text="CPU Fan: " Width="120" Margin="20,0,0,0"/>
                                    <TextBlock Text="{Binding CpuFanId}"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,4,0,0">
                                    <TextBlock Text="OS: " Width="120"/>
                                    <TextBlock Text="{Binding OperatingSystemId}"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,6,0,0">
                                    <TextBlock Text="Price: " Width="120"/>
                                    <TextBlock Text="{Binding Price}" FontWeight="Bold" Foreground="#27ae60"/>
                                </WrapPanel>

                            </StackPanel>

                            <Border Grid.Column="1"
                            Margin="10,0,0,0"
                            Background="#f4f6f7"
                            CornerRadius="6">
                                <Image Source="{Binding ComputerPicture,Converter={StaticResource ImageConverter}}" Stretch="Uniform" Margin="8"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</UserControl>