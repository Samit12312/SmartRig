<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SmartRigWPF"
    x:Class="SmartRigWPF.Frames.ManageComputers"
    Background="White"
    Width="730" Height="540">
    <UserControl.Resources>
        <local:ImageUrlToBitmapConverter x:Key="ImageConverter"/>
    </UserControl.Resources>
    <Grid>

        <TextBlock Text="Manage Computers"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"
                   Margin="20,20,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <StackPanel Orientation="Horizontal"
            Margin="20,65,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <Button Content="Add Computer" Width="120" Height="35"
            Background="#27ae60" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Button_Click"/>
            <Button Content="Edit Computer" Width="120" Height="35"
            Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0" Click="EditBtn_Click" />
            <Button Content="Delete Computer" Width="120" Height="35"
            Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0" Click="Button_Click_1"/>
        </StackPanel>


        <ListView x:Name="listView"
          Margin="20,133,20,125"
          BorderBrush="#dee2e6"
          BorderThickness="1"
          ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                    BorderBrush="#ecf0f1"
                    BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding computer.ComputerName}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
        <Run Text="Computer ID: "/>
        <Run Text="{Binding computer.ComputerId}"/>
                                </TextBlock>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="CPU:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="1" Text="{Binding cpu.CpuName}"/>
                                    <TextBlock Grid.Column="2" Text="GPU:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="3" Text="{Binding gpu.GpuName}"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="RAM:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ram.RamSize}"/>
                                    <TextBlock Grid.Column="2" Text="Storage:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="3" Text="{Binding storage.StorageName}"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Motherboard:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="1" Text="{Binding motherBoard.MotherBoardName}"/>
                                    <TextBlock Grid.Column="2" Text="Power Supply:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="3" Text="{Binding powerSupply.PowerSupplyName}"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Case:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="1" Text="{Binding computerCase.CaseName}"/>
                                    <TextBlock Grid.Column="2" Text="CPU Fan:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="3" Text="{Binding cpuFan.CpuFanName}"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="OS:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="1" Text="{Binding operatingSystem.OperatingSystemName}"/>
                                </Grid>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Price:" Foreground="#7f8c8d"/>
                                    <TextBlock Grid.Column="1" Text="{Binding computer.Price}" FontWeight="Bold" Foreground="#27ae60"/>
                                </Grid>
                            </StackPanel>

                            <Border Grid.Column="1"
                            Margin="10,0,0,0"
                            Background="#f4f6f7"
                            CornerRadius="6">
                                <Image Source="{Binding computer.ComputerPicture, Converter={StaticResource ImageConverter}}" Stretch="Uniform" Margin="8"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</UserControl>