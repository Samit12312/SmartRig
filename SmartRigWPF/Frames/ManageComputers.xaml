<UserControl x:Class="SmartRigWPF.Frames.ManageComputers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Manage Computers"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"
                   Margin="0,0,0,20"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Add Computer"
                    Width="120"
                    Height="35"
                    Background="#27ae60"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,10,0"
                    Cursor="Hand"/>
            <Button Content="Edit Computer"
                    Width="120"
                    Height="35"
                    Background="#3498db"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,10,0"
                    Cursor="Hand"/>
            <Button Content="Delete Computer"
                    Width="120"
                    Height="35"
                    Background="#e74c3c"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Data Grid -->
        <DataGrid Grid.Row="2"
                  Name="ComputersDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#f8f9fa"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ComputerId}" Width="60"/>
                <DataGridTextColumn Header="Name" Binding="{Binding ComputerName}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Company" Binding="{Binding CompanyId}" Width="100"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ComputerTypeId}" Width="80"/>
                <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystemId}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>