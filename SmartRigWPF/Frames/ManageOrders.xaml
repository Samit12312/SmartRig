<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SmartRigWPF"
    x:Class="SmartRigWPF.Frames.ManageOrders"
    Background="White"
    Width="730" Height="540">

    <Grid>

        <!-- Title -->
        <TextBlock Text="Manage Orders"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2c3e50"
                   Margin="20,20,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal"
            Margin="20,65,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <Button Content="View Details" Width="120" Height="35"
            Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Mark as Paid" Width="120" Height="35"
            Background="#27ae60" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0"/>
            <Button Content="Delete Order" Width="120" Height="35"
            Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand"
            Margin="10,0,0,0"/>
        </StackPanel>


        <!-- ListView -->
        <ListView x:Name="listView"
          Margin="20,120,20,30"
          BorderBrush="#dee2e6"
          BorderThickness="1"
                  Height="200"
          ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                    BorderBrush="#ecf0f1"
                    BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock FontSize="16" FontWeight="SemiBold">
                                    <Run Text="Order #"/>
                                    <Run Text="{Binding CartId}"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#7f8c8d" Margin="0,2,0,0">
                            <Run Text="User ID: "/>
                            <Run Text="{Binding UserId}"/>
                                </TextBlock>

                                <WrapPanel Margin="0,6,0,0">
                                    <TextBlock Text="Date: " Width="120"/>
                                    <TextBlock Text="{Binding Date}"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,4,0,0">
                                    <TextBlock Text="Payment Status: " Width="120"/>
                                    <TextBlock Text="{Binding IsPayed}" FontWeight="Bold" Foreground="#27ae60"/>
                                </WrapPanel>

                            </StackPanel>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</UserControl>